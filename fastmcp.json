{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "path": "src/ssh_mcp/server.py:mcp_server"
  },
  "deployment": {
    "transport": "stdio",
    "cwd": ".",
    "env": {
      "LOG_LEVEL": "INFO",
      "ALLOW_LOW_ACCESS_TOOLS": "false",
      "ALLOW_DANGEROUS_TOOLS": "false",
      "ALLOW_SUDO": "false"
    }
  }
}
