# Copy to .env for local development. Never commit real secrets.

# --- SSH transport ---
SSH_KNOWN_HOSTS=~/.ssh/known_hosts

# Optional OpenSSH client config to honor on top of hosts.toml. Most useful
# for inheriting `Host alias -> HostName ...`, `ProxyJump`, `IdentityFile`,
# and `Ciphers`/`MACs`/`KexAlgorithms` overrides without restating them in
# hosts.toml. Explicit hosts.toml fields ALWAYS WIN; the file only fills
# gaps. Leave blank to skip ssh_config entirely.
#   SSH_CONFIG_FILE=~/.ssh/config
SSH_CONFIG_FILE=

SSH_DEFAULT_USER=deploy
SSH_DEFAULT_KEY=~/.ssh/id_ed25519

# Per-host config registry (TOML). Missing file = env-only mode.
SSH_HOSTS_FILE=hosts.toml

# Directory of operator runbooks exposed via the FastMCP Skills provider.
# Missing dir is logged as INFO and skipped.
SSH_SKILLS_DIR=skills

# Per-host AGENT memory (INC-055). The LLM appends timestamped lessons
# to `<dir>/<alias>.md` via ssh_host_notes_append, reads via
# ssh_host_notes, consolidates via ssh_host_notes_set. Distinct from the
# operator-baseline `notes` field in hosts.toml -- the LLM only writes
# the sidecar, never the operator's TOML. Set blank to disable agent-side
# notes (the read-only operator layer remains).
SSH_HOST_NOTES_DIR=notes
# Cap on a single sidecar file (default 256 KiB). When approaching the
# cap, the LLM is instructed to consolidate via ssh_host_notes_set.
SSH_HOST_NOTES_MAX_BYTES=262144
# When true (default), ssh_host_ping auto-injects the host's operator
# notes (hosts.toml `notes` field) into its result. Makes the canonical
# "starting work on this host" probe surface hard-rule constraints into
# LLM context without needing a separate ssh_host_notes call. Set false
# for tool-execution-only deployments where ping should stay minimal.
SSH_PING_INCLUDES_NOTES=true

# Same idea for the AGENT layer (sidecar at <SSH_HOST_NOTES_DIR>/<alias>.md):
# when true (default), ssh_host_ping also includes the LLM's own learned
# facts in its result. Independent of SSH_PING_INCLUDES_NOTES so you can
# toggle the two layers separately. Trade-off: agent sidecars can grow
# to SSH_HOST_NOTES_MAX_BYTES (default 256 KiB) -- if your fleet's notes
# are large and ping context inflation matters, set this false and rely
# on the explicit ssh_host_notes tool.
SSH_PING_INCLUDES_AGENT_NOTES=true

# Reject password auth at hosts.toml load time unless explicitly enabled.
ALLOW_PASSWORD_AUTH=false

# --- Allowlists + blocklist (comma-separated OR JSON array) ---
# Blocklist wins over allowlist — use it for "never touch these" safety rails.
SSH_HOSTS_ALLOWLIST=bastion.example.com,db01.example.com
SSH_HOSTS_BLOCKLIST=
SSH_PATH_ALLOWLIST=/opt/app,/var/log,/etc/nginx
# Restricted zones inside the allowlist -- low-access + sftp-read tools refuse
# these paths even when they're inside path_allowlist. Use for SMB shares,
# backup mounts, etc. Unions with per-host `restricted_paths` in hosts.toml.
SSH_RESTRICTED_PATHS=
SSH_COMMAND_ALLOWLIST=

# --- Caps ---
SSH_CONNECT_TIMEOUT=10
SSH_COMMAND_TIMEOUT=60
SSH_IDLE_TIMEOUT=300
SSH_MAX_CONNECTIONS_PER_HOST=4
SSH_STDOUT_CAP_BYTES=1048576
SSH_STDERR_CAP_BYTES=1048576
SSH_EDIT_MAX_FILE_BYTES=10485760
SSH_UPLOAD_MAX_FILE_BYTES=268435456
SSH_FIND_MAX_DEPTH=10
SSH_FIND_MAX_RESULTS=10000
SSH_DELETE_FOLDER_MAX_ENTRIES=10000

# --- Local-path file transfer (MCP-host filesystem) ---
# Opt-in: set a comma-separated (or JSON) list of absolute directories on
# the MCP HOST (not the remote target) that ssh_upload / ssh_deploy /
# ssh_sftp_download are allowed to read from / write to when the caller
# passes `local_path=...`. Empty (default) disables the feature entirely
# -- no fallback to cwd, ~/Downloads, or MCP roots.
# Example: SSH_LOCAL_TRANSFER_ROOTS=/home/ops/uploads,/tmp/mcp-stage
SSH_LOCAL_TRANSFER_ROOTS=
# Size cap for local_path transfers only (bytes). Default 2 GiB. Separate
# from SSH_UPLOAD_MAX_FILE_BYTES which governs the base64 channel.
SSH_LOCAL_TRANSFER_MAX_BYTES=2147483648

# --- Access tiers (default-deny) ---
ALLOW_LOW_ACCESS_TOOLS=false
ALLOW_DANGEROUS_TOOLS=false
ALLOW_SUDO=false

# Empty command_allowlist = deny every exec (ADR-0018). Flip this to run
# arbitrary commands when no allowlist is configured.
ALLOW_ANY_COMMAND=false

# Default-on rejection of ssh_exec_run commands that match the cheatsheet
# (heredoc file-writes, leading `docker`/`systemctl <verb>`/`journalctl`/
# `apt(-get) install|remove|upgrade|...`, single mkdir/cp/mv/rm, file
# output redirection). When False (default), matching commands are
# refused with a hint pointing to the native MCP tool. Set to True to
# temporarily disable for legacy automation; agents should fix the
# automation rather than rely on this opt-out long-term.
# SSH_EXEC_ALLOW_CHEATSHEET_PATTERNS=false

# Global gate for persistent shell sessions (ssh_shell_open / ssh_shell_exec).
# Default true. Flip to false to hide those two tools entirely; ssh_shell_list
# and ssh_shell_close stay available for cleanup. Per-host override lives in
# hosts.toml as `persistent_session = true|false`. BOTH must be true to allow.
ALLOW_PERSISTENT_SESSIONS=true

# --- Tool catalog filter ---
# Empty = all groups visible (subject to tier gates). Explicit list trims
# to exactly those groups. Known: host, session, sftp-read, file-ops,
# exec, sudo, shell, docker, keys, systemctl, pkg.
SSH_ENABLED_GROUPS=

# --- BM25 search transform (tool discovery) ---
# With 50+ tools the full tools/list schema is expensive per turn. Flip ON
# to replace the catalog with two synthetic tools -- search_tools(query) +
# call_tool(name, args) -- plus any names in SSH_BM25_ALWAYS_VISIBLE.
# The LLM searches for what it needs on demand.
SSH_ENABLE_BM25=false
SSH_BM25_MAX_RESULTS=8
# Pinned tools that stay in tools/list regardless of BM25 (discoverability
# anchor). Keep small. Comma-separated or JSON array.
SSH_BM25_ALWAYS_VISIBLE=ssh_host_ping,ssh_host_info,ssh_session_list,ssh_shell_list

# --- Sudo ---
# Password sourcing priority (per call):
#   1. OS keyring entry  service=ssh-mcp-sudo  user=<host alias>     (per-host)
#   2. SSH_SUDO_PASSWORD_CMD                                          (global cmd)
#   3. OS keyring entry  service=ssh-mcp-sudo  user=default           (fleet fallback)
#   4. None -> passwordless sudoers (sudo -n)
# Set a per-host password once:
#   python -c "import keyring; keyring.set_password('ssh-mcp-sudo','alfred','...')"
SSH_SUDO_MODE=per-call
SSH_SUDO_PASSWORD_CMD=

# --- Docker ---
# The Docker CLI. Default `docker`; set to `podman` for Podman hosts
# (API-compatible CLI + JSON output). Per-host override: `docker_cmd = "podman"`
# in hosts.toml. Shell-split so operators can prepend sudo / env / wrappers:
#   SSH_DOCKER_CMD="sudo docker"
SSH_DOCKER_CMD=docker

# Compose invocation. Empty = derive at runtime as `{SSH_DOCKER_CMD} compose`
# so podman hosts automatically get `podman compose`. Set explicitly only
# for legacy standalone binaries:
#   SSH_DOCKER_COMPOSE_CMD=docker-compose
#   SSH_DOCKER_COMPOSE_CMD=podman-compose
SSH_DOCKER_COMPOSE_CMD=

# ssh_docker_run rejects host-escape flags (--privileged, --cap-add,
# --network=host, --pid=host, host-rooted --volume=/:..., etc.) by default,
# even when ALLOW_DANGEROUS_TOOLS is true. Those flags grant effective root on
# the SSH target. Flip to true ONLY if you need them and understand the
# blast radius -- this bypass is visible in audit logs.
ALLOW_DOCKER_PRIVILEGED=false

# --- Runbooks (workflow skills, separate from per-tool skills) ---
# Workflow runbooks (incident response, deploy+verify, integrity audit, ...)
# live in runbooks/ and mount as a second FastMCP SkillsDirectoryProvider.
# Flip to false for tool-execution-only assistants that don't need the
# narrative runbooks in resources/list. Per-tool skills under SSH_SKILLS_DIR
# are always mounted; this flag only affects runbooks/.
SSH_ENABLE_RUNBOOKS=true
SSH_RUNBOOKS_DIR=runbooks

# --- Hooks (no hooks registered by default) ---
# Dotted import path of an operator-supplied module exposing
#   def register_hooks(registry: HookRegistry) -> None
# Missing or broken module is a WARNING, not a startup failure.
SSH_HOOKS_MODULE=

# --- MCP transport ---
# Default `stdio` matches every MCP client launcher. Flip to `http` (alias
# for streamable-http), `streamable-http`, or `sse` to expose over HTTP.
# There is NO built-in auth or TLS -- only bind to loopback unless you've
# put a reverse proxy with auth in front.
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000

# --- Observability ---
LOG_LEVEL=INFO
# Open telemetry spans for ssh.connect / ssh.exec / sftp.op. Defaults true so
# operators see traces out of the box; flip to false to disable the FastMCP
# tracer lookup entirely (no spans emitted, no attributes set, no per-call
# import cost beyond a settings lookup).
OTEL_ENABLED=true
